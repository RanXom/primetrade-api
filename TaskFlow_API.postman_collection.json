{
  "info": {
    "name": "TaskFlow API v1",
    "description": "Complete Postman collection for TaskFlow REST API.\n\nSetup:\n1. Set `baseUrl` variable to your API host (default: http://localhost:8000)\n2. Run the `Login` request — the collection auto-saves the token\n3. All authenticated requests use {{accessToken}} automatically\n\nDefault admin: admin@taskflow.dev / Admin1234!",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "taskId", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health",
            "description": "Check API health status"
          }
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"username\": \"johndoe\",\n  \"password\": \"Secure1234\",\n  \"full_name\": \"John Doe\"\n}"
            },
            "description": "Register a new user. Password must have uppercase, lowercase, and digit."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data) {",
                  "  pm.collectionVariables.set('accessToken', res.data.access_token);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refresh_token);",
                  "  console.log('✅ Tokens saved to collection variables');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@taskflow.dev\",\n  \"password\": \"Admin1234!\"\n}"
            },
            "description": "Login and receive JWT access + refresh tokens. Tokens are auto-saved to collection variables."
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data) {",
                  "  pm.collectionVariables.set('accessToken', res.data.access_token);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
            },
            "description": "Exchange a refresh token for new access + refresh tokens."
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "description": "Get the authenticated user's profile."
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/auth/me/password",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"Admin1234!\",\n  \"new_password\": \"NewSecure5678\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "List My Tasks",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/tasks?page=1&page_size=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tasks"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "page_size", "value": "20" },
                { "key": "status", "value": "todo", "disabled": true },
                { "key": "priority", "value": "high", "disabled": true },
                { "key": "search", "value": "keyword", "disabled": true }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "description": "List tasks owned by the authenticated user. Supports pagination and filtering."
          }
        },
        {
          "name": "Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data) {",
                  "  pm.collectionVariables.set('taskId', res.data.id);",
                  "  console.log('Task ID saved:', res.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/tasks",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Implement OAuth2 login\",\n  \"description\": \"Add Google and GitHub OAuth2 providers\",\n  \"status\": \"todo\",\n  \"priority\": \"high\",\n  \"is_public\": false,\n  \"due_date\": \"2025-12-31T23:59:00Z\"\n}"
            },
            "description": "Create a new task. The task ID is auto-saved to {{taskId}}."
          }
        },
        {
          "name": "Get Task by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/tasks/{{taskId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "description": "Get a specific task. Public tasks are accessible without auth."
          }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/v1/tasks/{{taskId}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_progress\",\n  \"priority\": \"urgent\"\n}"
            },
            "description": "Partially update a task. Only include fields you want to change."
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/tasks/{{taskId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "List Public Tasks",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/tasks/public?page=1&page_size=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tasks", "public"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "page_size", "value": "20" }
              ]
            },
            "description": "List public tasks. No authentication required."
          }
        },
        {
          "name": "[Admin] List All Tasks",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/tasks/admin/all?page=1&page_size=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tasks", "admin", "all"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "page_size", "value": "20" },
                { "key": "user_id", "value": "{{userId}}", "disabled": true }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "description": "Admin only: list all tasks across all users."
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "List All Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/users?page=1&page_size=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "users"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "page_size", "value": "20" },
                { "key": "search", "value": "", "disabled": true }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/admin/users/{{userId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Update User (role / active)",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/v1/admin/users/{{userId}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"admin\",\n  \"is_active\": true\n}"
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/admin/users/{{userId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    }
  ]
}
